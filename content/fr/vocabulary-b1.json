    { "text": "Nous devons {1} nos efforts.", "blanks": [ { "cue": "to maintain", "answer": ["maintenir"] } ], "explanation": "maintenir = to maintain (infinitive)." },
    { "text": "Ce produit respecte la {1}.", "blanks": [ { "cue": "nature", "answer": ["nature"] } ], "explanation": "nature = nature (feminine)." },
    { "text": "La recherche a fait un grand {1}.", "blanks": [ { "cue": "progress", "answer": ["progrès"] } ], "explanation": "progrès = progress (masculine, invariable)." },
    { "text": "Il faut {1} sa consommation d'énergie.", "blanks": [ { "cue": "to control", "answer": ["maîtriser"] } ], "explanation": "maîtriser = to control/master (infinitive)." },
    { "text": "Cette mesure semble peu {1}.", "blanks": [ { "cue": "realistic", "answer": ["réaliste"] } ], "explanation": "réaliste = realistic (same in masculine and feminine)." },
    { "text": "Le rapport montre une nette {1} des ventes.", "blanks": [ { "cue": "increase", "answer": ["hausse"] } ], "explanation": "hausse = rise/increase (feminine)." }
