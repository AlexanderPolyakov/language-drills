  "title": "Adverbs of frequency",
  "lesson": "Adverbs of frequency show how often: always (100%), usually, often, sometimes, rarely, never (0%). They usually go before the main verb but after 'to be'.",
  "items": [
    { "text": "The sun {1} rises in the east (100%).", "blanks": [ { "options": ["always", "never", "sometimes"], "answer": "always" } ], "explanation": "100% of the time means 'always'." },
    { "text": "I {1} eat meat; I'm a vegetarian (0%).", "blanks": [ { "options": ["never", "always", "often"], "answer": "never" } ], "explanation": "0% of the time means 'never'." },
    { "text": "She {1} drinks coffee in the morning (about 90%).", "blanks": [ { "options": ["usually", "rarely", "never"], "answer": "usually" } ], "explanation": "Around 90% is 'usually'." },
    { "text": "We {1} go to the cinema (about 60%).", "blanks": [ { "options": ["often", "never", "rarely"], "answer": "often" } ], "explanation": "Around 60% is 'often'." },
    { "text": "He {1} eats fast food (about 30%).", "blanks": [ { "options": ["sometimes", "always", "usually"], "answer": "sometimes" } ], "explanation": "Around 30% is 'sometimes'." },
    { "text": "They {1} watch TV; they prefer reading (about 10%).", "blanks": [ { "options": ["rarely", "usually", "always"], "answer": "rarely" } ], "explanation": "Around 10% is 'rarely'." },
    { "text": "I am {1} late for work; I value being on time (0%).", "blanks": [ { "options": ["never", "always", "often"], "answer": "never" } ], "explanation": "0% with 'to be': adverb goes after 'am'." },
