  "title": "Superlatives: the -est / the most…",
  "lesson": "Short adjectives add 'the …-est' (the tallest). Longer ones use 'the most …' (the most expensive). Some are irregular: good→the best, bad→the worst.",
  "items": [
    { "text": "Everest is {1} mountain in the world.", "blanks": [ { "cue": "high", "answer": ["the highest"] } ], "explanation": "Short adjective: add 'the' + -est." },
    { "text": "This is {1} car in the shop.", "blanks": [ { "cue": "expensive", "answer": ["the most expensive"] } ], "explanation": "Long adjective: use 'the most'." },
    { "text": "He is {1} student in the class.", "blanks": [ { "cue": "good", "answer": ["the best"] } ], "explanation": "'good' is irregular: the best." },
    { "text": "That was {1} film I have ever seen.", "blanks": [ { "cue": "bad", "answer": ["the worst"] } ], "explanation": "'bad' is irregular: the worst." },
    { "text": "The Nile is one of {1} rivers on Earth.", "blanks": [ { "cue": "long", "answer": ["the longest"] } ], "explanation": "Short adjective: add 'the' + -est." },
    { "text": "This is {1} box; let me carry it.", "blanks": [ { "cue": "big", "answer": ["the biggest"] } ], "explanation": "'big' doubles the g: the biggest." },
    { "text": "She lives in {1} house on the street.", "blanks": [ { "cue": "small", "answer": ["the smallest"] } ], "explanation": "Short adjective: add 'the' + -est." },
    { "text": "It was {1} day of the trip.", "blanks": [ { "cue": "hot", "answer": ["the hottest"] } ], "explanation": "'hot' doubles the t: the hottest." },
    { "text": "Russia is {1} country in the world.", "blanks": [ { "cue": "large", "answer": ["the largest"] } ], "explanation": "Ends in -e, so add only -st: the largest." },
    { "text": "This puzzle is {1} of them all.", "blanks": [ { "cue": "difficult", "answer": ["the most difficult"] } ], "explanation": "Long adjective: use 'the most'." },
    { "text": "He is {1} runner on the team.", "blanks": [ { "cue": "fast", "answer": ["the fastest"] } ], "explanation": "Short adjective: add 'the' + -est." },
    { "text": "That's {1} cake on the menu.", "blanks": [ { "cue": "delicious", "answer": ["the most delicious"] } ], "explanation": "Long adjective: use 'the most'." },
    { "text": "Neptune is {1} planet from the sun.", "blanks": [ { "cue": "far", "answer": ["the furthest", "the farthest"] } ], "explanation": "'far' is irregular: the furthest/farthest." },
