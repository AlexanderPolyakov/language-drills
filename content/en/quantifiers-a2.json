{
  "id": "en-quantifiers-a2",
  "lang": "en",
  "topic": "quantifiers",
  "level": "A2",
  "type": "cloze",
  "title": "some, any, much, many, a lot of",
  "lesson": "Use 'some' in affirmatives, 'any' in negatives and questions. Use 'much' with uncountable nouns, 'many' with countable ones; 'a lot of' works with both.",
  "items": [
    { "text": "I have {1} money in my wallet.", "blanks": [ { "options": ["some", "any", "many"], "answer": "some" } ], "explanation": "Affirmative + uncountable noun takes 'some'." },
    { "text": "Do you have {1} brothers or sisters?", "blanks": [ { "options": ["some", "any", "much"], "answer": "any" } ], "explanation": "Questions usually take 'any'." },
    { "text": "There aren't {1} eggs in the fridge.", "blanks": [ { "options": ["any", "some", "much"], "answer": "any" } ], "explanation": "Negatives take 'any'." },
    { "text": "How {1} water do you drink each day?", "blanks": [ { "options": ["much", "many", "some"], "answer": "much" } ], "explanation": "'How much' goes with uncountable 'water'." },
    { "text": "How {1} people came to the party?", "blanks": [ { "options": ["many", "much", "any"], "answer": "many" } ], "explanation": "'How many' goes with countable 'people'." },
    { "text": "She has {1} of friends at school.", "blanks": [ { "options": ["a lot", "much", "many"], "answer": "a lot" } ], "explanation": "'a lot of' works with countable nouns." },
    { "text": "We don't have {1} time before the train.", "blanks": [ { "options": ["much", "many", "some"], "answer": "much" } ], "explanation": "Negative + uncountable 'time' takes 'much'." },
    { "text": "Would you like {1} coffee?", "blanks": [ { "options": ["some", "any", "many"], "answer": "some" } ], "explanation": "Offers use 'some' even though they are questions." },
    { "text": "There are {1} apples on the table.", "blanks": [ { "options": ["some", "any", "much"], "answer": "some" } ], "explanation": "Affirmative + countable noun takes 'some'." },
    { "text": "I don't have {1} sugar left.", "blanks": [ { "options": ["any", "many", "some"], "answer": "any" } ], "explanation": "Negative + uncountable takes 'any'." },
    { "text": "There are too {1} cars in this city.", "blanks": [ { "options": ["many", "much", "some"], "answer": "many" } ], "explanation": "'too many' goes with countable 'cars'." },
    { "text": "Is there {1} milk left?", "blanks": [ { "options": ["any", "some", "many"], "answer": "any" } ], "explanation": "Questions take 'any'." },
    { "text": "He spends a {1} of money on games.", "blanks": [ { "options": ["lot", "much", "many"], "answer": "lot" } ], "explanation": "'a lot of' works with uncountable 'money'." },
    { "text": "We have {1} bread for sandwiches.", "blanks": [ { "options": ["some", "any", "many"], "answer": "some" } ], "explanation": "Affirmative + uncountable takes 'some'." },
    { "text": "There isn't {1} cheese in the salad.", "blanks": [ { "options": ["much", "many", "some"], "answer": "much" } ], "explanation": "Negative + uncountable takes 'much'." },
    { "text": "How {1} sugar do you take in tea?", "blanks": [ { "options": ["much", "many", "any"], "answer": "much" } ], "explanation": "'How much' with uncountable 'sugar'." },
    { "text": "There aren't {1} chairs in the room.", "blanks": [ { "options": ["many", "much", "some"], "answer": "many" } ], "explanation": "Negative + countable takes 'many'." },
    { "text": "Can I have {1} water, please?", "blanks": [ { "options": ["some", "any", "much"], "answer": "some" } ], "explanation": "Requests use 'some'." },
    { "text": "I don't know {1} of the answers.", "blanks": [ { "options": ["any", "some", "much"], "answer": "any" } ], "explanation": "Negative takes 'any'." },
    { "text": "She has a {1} of homework tonight.", "blanks": [ { "options": ["lot", "many", "much"], "answer": "lot" } ], "explanation": "'a lot of' with uncountable 'homework'." },
    { "text": "Are there {1} questions about the test?", "blanks": [ { "options": ["any", "some", "much"], "answer": "any" } ], "explanation": "Questions take 'any'." },
    { "text": "We bought {1} new furniture.", "blanks": [ { "options": ["some", "any", "many"], "answer": "some" } ], "explanation": "Affirmative + uncountable 'furniture' takes 'some'." },
    { "text": "How {1} languages can you speak?", "blanks": [ { "options": ["many", "much", "some"], "answer": "many" } ], "explanation": "'How many' with countable 'languages'." },
    { "text": "There isn't {1} space in the bag.", "blanks": [ { "options": ["much", "many", "any"], "answer": "much" } ], "explanation": "Negative + uncountable 'space' takes 'much'." },
    { "text": "I saw {1} interesting shops downtown.", "blanks": [ { "options": ["some", "any", "much"], "answer": "some" } ], "explanation": "Affirmative + countable takes 'some'." },
    { "text": "Do we need {1} milk from the shop?", "blanks": [ { "options": ["any", "some", "many"], "answer": "any" } ], "explanation": "Questions take 'any'." },
    { "text": "There are {1} of tourists in summer.", "blanks": [ { "options": ["a lot", "much", "any"], "answer": "a lot" } ], "explanation": "'a lot of' with countable 'tourists'." },
    { "text": "He doesn't eat {1} vegetables.", "blanks": [ { "options": ["many", "much", "some"], "answer": "many" } ], "explanation": "Negative + countable 'vegetables' takes 'many'." },
    { "text": "I'd like {1} more rice, please.", "blanks": [ { "options": ["some", "any", "many"], "answer": "some" } ], "explanation": "Requests/offers use 'some'." },
    { "text": "There wasn't {1} traffic this morning.", "blanks": [ { "options": ["much", "many", "some"], "answer": "much" } ], "explanation": "Negative + uncountable 'traffic' takes 'much'." },
    { "text": "How {1} time do we have left?", "blanks": [ { "options": ["much", "many", "any"], "answer": "much" } ], "explanation": "'How much' with uncountable 'time'." },
    { "text": "She read {1} books last summer.", "blanks": [ { "options": ["a lot of", "much", "any"], "answer": "a lot of" } ], "explanation": "'a lot of' with countable 'books'." },
    { "text": "We didn't see {1} stars last night.", "blanks": [ { "options": ["many", "much", "some"], "answer": "many" } ], "explanation": "Negative + countable 'stars' takes 'many'." },
    { "text": "Is there {1} bread for breakfast?", "blanks": [ { "options": ["any", "some", "many"], "answer": "any" } ], "explanation": "Questions take 'any'." }
  ]
}
