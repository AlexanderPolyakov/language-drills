  "title": "Present continuous: am/is/are + -ing",
  "lesson": "Use am/is/are + verb-ing for actions happening now. The subject decides am (I), is (he/she/it), or are (you/we/they).",
  "items": [
    {
      "text": "I {1} a letter right now.",
      "blanks": [ { "cue": "write", "answer": ["am writing", "'m writing"] } ],
      "explanation": "I takes 'am'; 'write' drops the e before -ing."
    },
    {
      "text": "She {1} to music in her room.",
      "blanks": [ { "cue": "listen", "answer": ["is listening", "'s listening"] } ],
      "explanation": "She takes 'is' + listening."
    },
    {
      "text": "We {1} football in the park.",
      "blanks": [ { "cue": "play", "answer": ["are playing", "'re playing"] } ],
      "explanation": "We takes 'are' + playing."
    },
    {
      "text": "He {1} fast because he is late.",
      "blanks": [ { "cue": "run", "answer": ["is running", "'s running"] } ],
      "explanation": "Short vowel + single consonant: 'run' doubles the n to make running."
    },
    {
      "text": "They {1} dinner in the kitchen.",
      "blanks": [ { "cue": "make", "answer": ["are making", "'re making"] } ],
      "explanation": "'make' drops the final e before -ing."
    },
    {
      "text": "You {1} too much noise!",
      "blanks": [ { "cue": "make", "answer": ["are making", "'re making"] } ],
      "explanation": "You takes 'are' + making."
    },
    {
      "text": "The baby {1} right now.",
